# ============================================================
# AI Knowledge & Decision Support System — Environment Config
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Pinecone (required) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=documents

# --- HuggingFace (required) ---
HUGGINGFACE_API_TOKEN=hf_your_token_here
LLM_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# --- Embedding (optional — defaults shown) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Application tuning (optional — defaults shown) ---
DEBUG=false
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
MAX_QUERY_LENGTH=1000

# --- File storage (optional — defaults shown) ---
UPLOAD_FOLDER=data/uploaded_documents
PROCESSED_FOLDER=data/processed

# --- FastAPI backend (optional — defaults shown) ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
